@page "/plan/details/{id:int}"
@using AppForSEII2526.Web.API
@inject NavigationManager navigation
@inject ILogger<PlanDetails> logger

<h3>Plan Details</h3>

@if (error)
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
    <button class="btn btn-primary" @onclick="GoBack">Back to Home</button>
}
else if (plan == null)
{
    <p>Loading plan details...</p>
}
else
{
    @* step 7: show the plan performed *@
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h2>@plan.Name</h2>
            </div>
            <div class="card-body">

                @* plan metadata *@
                <dl class="row">
                    @* user's data (name and surname) *@
                    <dt class="col-sm-3">User</dt>
                    <dd class="col-sm-9">@plan.UserFullName</dd>

                    @* when the plan was made *@
                    <dt class="col-sm-3">Created Date</dt>
                    <dd class="col-sm-9">@plan.CreatedDate.DateTime.ToShortDateString() @plan.CreatedDate.DateTime.ToShortTimeString()</dd>

                    @* total price *@
                    <dt class="col-sm-3">Total Price</dt>
                    <dd class="col-sm-9">@plan.TotalPrice.ToString("C2")</dd>

                    @* number of weeks *@
                    <dt class="col-sm-3">Weeks</dt>
                    <dd class="col-sm-9">@plan.Weeks</dd>

                    @* description *@
                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@(string.IsNullOrEmpty(plan.Description) ? "N/A" : plan.Description)</dd>

                    @* health issues *@
                    <dt class="col-sm-3">Health Issues</dt>
                    <dd class="col-sm-9">@(string.IsNullOrEmpty(plan.HealthIssues) ? "None" : plan.HealthIssues)</dd>
                </dl>

                <h4 class="mt-4">Classes Enrolled</h4>

                @* classes enrolled in (name, type, price, date, time and goals) *@
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Class Name</th>
                                <th>Type</th>
                                <th>Date & Time</th>
                                <th>Price</th>
                                <th>Goal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (plan.PlanItems != null && plan.PlanItems.Any())
                            {
                                @foreach (var item in plan.PlanItems)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@(item.Type != null ? string.Join(", ", item.Type) : "")</td>
                                        <td>@item.Date.DateTime.ToShortDateString() @item.Date.DateTime.ToShortTimeString()</td>
                                        <td>@item.Price.ToString("C2")</td>
                                        <td>@(string.IsNullOrEmpty(item.Goal) ? "-" : item.Goal)</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5">No classes found in this plan.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary" @onclick="GoBack">Back to Home</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // dependencies
    [Inject] private AppForSEII2526APIClient Apiclient { get; set; } = default!;

    [Parameter]
    public int Id { get; set; }

    private PlanForDetailDTO? plan;
    private bool error = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // api call
            plan = await Apiclient.GetPlanAsync(Id);
        }
        catch (ApiException ex)
        {
            if (ex.StatusCode == 404)
            {
                errorMessage = "The requested plan was not found.";
            }
            else
            {
                errorMessage = $"Error loading plan: {ex.Message}";
            }
            error = true;
            logger.LogError(ex, "Error fetching plan details for Id {Id}", Id);
        }
        catch (Exception ex)
        {
            errorMessage = "An unexpected error occurred.";
            error = true;
            logger.LogError(ex, "Unexpected error fetching plan details for Id {Id}", Id);
        }
    }

    private void GoBack()
    {
        navigation.NavigateTo("/");
    }
}