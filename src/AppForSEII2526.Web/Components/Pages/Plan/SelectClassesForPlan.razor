@page "/plan/selectclassesforplan"

@using Microsoft.AspNetCore.Authorization
@using AppForSEII2526.Web.API
@inject AppForSEII2526APIClient apiclient
@inject ILogger<SelectClassesForPlan> logger
@inject PlanStateContainer planState
@inject NavigationManager navigation
@*@attribute [Authorize]*@



<h3>Select Classes For Planning</h3>
<div class="container-fluid">
    @* Display Errors *@
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @errors</p>
    </div>

    <div class="row">
        @* Search and Filter Panel (Main Flow - Step 2) *@
        <div class="col-8">
            <div class="row">
                @* Filter by Class Name *@
                <div class="col-4">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="class-name-addon">Class Name</span>
                        <input type="text" id="inputClassName" @bind="className" @bind:event="oninput" class="form-control" placeholder="Name" aria-label="Name" aria-describedby="class-name-addon">
                    </div>
                </div>

                @* Filter by Date (Starting From) - Matches API signature: GetClassesForPlan(name, date) *@
                <div class="col-4">
                    <div class="input-group mb-3">
                        <span class="input-group-text">Starting From</span>
                        <InputDate @bind-Value="@FromDate" id="fromDate" />
                    </div>
                </div>

                @* The 'Type' and 'To Date' filters are omitted to match your current API endpoint *@

                <div class="col-4">
                    <button type="button" class="btn btn-primary" @onclick="SearchClasses" id="searchClasses">Search Classes</button>
                </div>
            </div>

            @* Available Classes List (Main Flow - Step 2) *@
            <div class="row">
                @if (classes == null)
                {
                    <p>Loading classes....</p>
                }
                else if (!classes.Any() && !string.IsNullOrEmpty(lastSearchAttempt))
                {
                    @* Alternative Flow 0: No classes available *@
                    <div class="alert alert-warning" role="alert">
                        No available classes found with the selected filters.
                    </div>
                }
                else
                {
                    <div class="mh-100 table-responsive">
                        <table class="table table-condensed table-hover" id="TableOfClasses">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Price</th>
                                    <th>Required Items</th>
                                    <th>Date and Time</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var classItem in classes)
                                {
                                    @* Only display classes not already in the plan *@
                                    @if (!PlanState.SelectedClasses.Any(c => c.Id == classItem.Id))
                                    {
                                        <tr id="ClassData_@classItem.Name">
                                            <td>@classItem.Name</td>
                                            <td>@classItem.Price.ToString("C2")</td>
                                            <td>@(string.Join(", ", classItem.TypeItems))</td>
                                            <td>@classItem.Date.DateTime.ToShortDateString() @classItem.Date.DateTime.ToShortTimeString()</td>
                                            <td>
                                                <button class="btn btn-outline-secondary" id="classToSelect_@classItem.Name" @onclick="@(() => AddClass(classItem))">Select</button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* Plan Cart (Selected Classes & Total Price) (Main Flow - Steps 2 & 3) *@
        <div class="col-4" hidden="@hidePlanCart">
            <div class="row">
                <h3>Selected Classes</h3>
            </div>
            @foreach (ClassForPlanDTO item in PlanState.SelectedClasses)
            {
                <div class="row">
                    <button type="button" class="btn btn-light" id="removeClass_@item.Name" @onclick="@(() => RemoveClass(item))">
                        x @item.Name - @item.Price.ToString("C2")
                    </button>
                </div>
            }
            <div class="row mt-3">
                <h4>Total Price: <span id="TotalPlanPrice">@TotalPlanPrice.ToString("C2")</span></h4>
            </div>
            <div class="row">
                @* Continue Button (Step 4). Disabled if no classes selected (Alternative Flow 4) *@
                <button type="button" class="btn btn-success mt-2" id="continueToCreatePlanButton" @onclick="ContinueToCreatePlan" disabled="@(PlanState.SelectedClasses.Count == 0)">
                    Continue (@PlanState.SelectedClasses.Count classes)
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    // Inject dependencies
    [Inject] private AppForSEII2526APIClient Apiclient { get; set; } = default!;
    [Inject] private PlanStateContainer PlanState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ILogger<SelectClassesForPlan> Logger { get; set; } = default!;

    private ICollection<ClassForPlanDTO>? classes;
    private string errors = string.Empty;
    private string className = string.Empty;
    private string lastSearchAttempt = string.Empty;

    // UI properties
    private bool hidePlanCart => PlanState.SelectedClasses.Count == 0;
    private bool hideErrors => string.IsNullOrEmpty(errors);

    private DateTime _fromDate;
    private DateTime FromDate
    {
        get => _fromDate;
        set
        {
            if (_fromDate != value)
            {
                _fromDate = value;
                // Clear the cart when search date changes to ensure selection validity
                PlanState.ClearPlanCart();
            }
        }
    }

    private decimal TotalPlanPrice => (decimal)PlanState.SelectedClasses.Sum(c => c.Price);


    protected override async Task OnInitializedAsync()
    {
        // Subscribe to state changes to refresh UI when the cart changes
        PlanState.OnChange += StateHasChanged;

        DateTime today = DateTime.Today.Date;

        if (_fromDate == default)
        {
            // Default search date to today
            _fromDate = DateTime.SpecifyKind(today, DateTimeKind.Unspecified);
        }

        await SearchClasses();
    }

    public void Dispose()
    {
        PlanState.OnChange -= StateHasChanged;
    }

    private void AddClass(ClassForPlanDTO classItem)
    {
        PlanState.AddClassToPlan(classItem);
    }

    private void RemoveClass(ClassForPlanDTO item)
    {
        PlanState.RemoveClassFromPlan(item);
    }

    public async Task SearchClasses()
    {
        errors = string.Empty;
        lastSearchAttempt = "Attempted";

        // Date validation (Alternative Flow 2)
        if (FromDate.Date < DateTime.Today.Date)
        {
            errors = "The search starting date cannot be earlier than today. (Alternative Flow 2)";
            return;
        }

        try
        {
            // API Call: Using the implemented GetClassesForPlan(string? name, DateTime? date)
            // Note: Your API uses DateTime, not DateTimeOffset, so we pass FromDate directly.
            classes = await Apiclient.GetClassesForPlanAsync(className, FromDate);
            errors = string.Empty;

            if (classes == null || !classes.Any())
            {
                // Alternative Flow 0 handling
                errors = "No available classes found with the search criteria. (Alternative Flow 0)";
                classes = new List<ClassForPlanDTO>();
            }
        }
        catch (ApiException ex)
        {
            Logger.LogError(ex, "Error searching for classes: {Message}", ex.Message);
            errors = "Error connecting to the system or loading available classes.";
            classes = new List<ClassForPlanDTO>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error searching for classes: {Message}", ex.Message);
            errors = "Unexpected error: " + ex.Message;
            classes = new List<ClassForPlanDTO>();
        }

        StateHasChanged();
    }

    private void ContinueToCreatePlan()
    {
        // Navigate to the plan creation page to complete Step 5 (Request remaining mandatory data)
        Navigation.NavigateTo("/plan/createplan");
    }
}



